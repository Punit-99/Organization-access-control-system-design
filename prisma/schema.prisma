datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OrgCategory {
  BROKER
  OPERATOR
  FBO
}

enum Feature {
  VIEW_TRANSACTIONS
  CREATE_TRANSACTION
  MANAGE_USERS
  CONFIGURE_ROUTING
}

model Organization {
  id        String      @id @default(cuid())
  name      String
  category  OrgCategory
  users     User[]
  createdAt DateTime    @default(now())
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  passwordHash String
  isAdmin      Boolean          @default(false)
  orgId        String
  org          Organization     @relation(fields: [orgId], references: [id])
  permissions  UserPermission[]
  createdAt    DateTime         @default(now())
}

// Entitlement layer — which features a CATEGORY unlocks.
model CategoryEntitlement {
  id       String      @id @default(cuid())
  category OrgCategory
  feature  Feature

  @@unique([category, feature])
}

// Grant layer — which features a USER actually has.
model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  feature   Feature
  grantedBy String?  // userId of the admin who granted it, nullable for seed-time grants
  createdAt DateTime @default(now())

  @@unique([userId, feature])
}

// Stretch: audit log
model PermissionAuditLog {
  id        String   @id @default(cuid())
  orgId     String
  targetUserId String
  actorId   String        // admin who performed the action
  feature   Feature
  action    String        // "GRANT" | "REVOKE"
  createdAt DateTime @default(now())
}
